# Port configurations
PORT=5000

# MongoDB Connection String
MONGO_URI=mongodb://localhost:27017/student_city_discovery

# JWT Secret key for token generation
JWT_SECRET=your_jwt_secret_key_here

# Google OAuth Credentials (for Google Login Strategy)
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_CALLBACK_URL=https://stay-sync-gamma.vercel.app/api/users/auth/google/callback

# Nodemailer SMTP Configuration (Gmail recommended)
EMAIL_USER=your_email_address@gmail.com
EMAIL_PASS=your_email_app_password_here

# Frontend Application URL (for CORS and redirects)
# Use the deployed frontend URL and optionally include multiple origins as a comma-separated list.
# Example: FRONTEND_URL=https://staynst.netlify.app,http://localhost:5173
FRONTEND_URL=https://staynst.netlify.app
